#: mousepad/mousepad-application.c:158
msgid ""
"Encoding to be used to open files (leave empty to open files in the encoding"
" dialog)"
msgstr "ລະຫັດຕົວອັກສອນທີ່ຈະໃຊ້ເພື່ອເປີດໄຟລ໌ (ປະຫວ່າງໄວ້ເພື່ອເປີດໄຟລ໌ໃນໜ້າຕ່າງລະຫັດຕົວອັກສອນ)"

#: mousepad/mousepad-application.c:159
msgid "ENCODING"
msgstr "ລະຫັດຕົວອັກສອນ"

#: mousepad/mousepad-application.c:163
msgid "Display a list of possible encodings to open files"
msgstr "ສະແດງລາຍຊື່ລະຫັດຕົວອັກສອນທີ່ເປັນໄປໄດ້ເພື່ອເປີດໄຟລ໌"

#: mousepad/mousepad-application.c:167
msgid ""
"Line number the cursor to position to (LINE > 0 from top, LINE < 0 from "
"bottom)"
msgstr "ເລກແຖວທີ່ຈະວາງຕຳແໜ່ງເຄີເຊີ (LINE > 0 ຈາກເທິງ, LINE < 0 ຈາກລຸ່ມ)"

#: mousepad/mousepad-application.c:168
msgid "LINE"
msgstr "ແຖວ"

#: mousepad/mousepad-application.c:172
msgid ""
"Column number the cursor to position to (COLUMN >= 0 from start, COLUMN < 0 "
"from end)"
msgstr "ເລກຖັນທີ່ຈະວາງຕຳແໜ່ງເຄີເຊີ (COLUMN >= 0 ຈາກເລີ່ມຕົ້ນ, COLUMN < 0 ຈາກທ້າຍ)"

#: mousepad/mousepad-application.c:173
msgid "COLUMN"
msgstr "ຖັນ"

#: mousepad/mousepad-application.c:177
msgid "Open the preferences dialog"
msgstr "ເປີດໜ້າຕ່າງການຕັ້ງຄ່າ"

#: mousepad/mousepad-application.c:181
msgid "Do not register with the D-BUS session message bus"
msgstr "ບໍ່ຕ້ອງລົງທະບຽນກັບ D-BUS session message bus"

#: mousepad/mousepad-application.c:185
msgid "Quit a running Mousepad primary instance"
msgstr "ອອກຈາກ Mousepad ຕົວຫຼັກທີ່ກຳລັງເຮັດວຽກຢູ່"

#: mousepad/mousepad-application.c:189
msgid "Print version information and exit"
msgstr "ສະແດງຂໍ້ມູນເວີຊັນແລ້ວອອກ"

#: mousepad/mousepad-application.c:193
msgid "[FILES...]"
msgstr "[ໄຟລ໌...]"

#. this option is added separately using g_strdup_printf() for the
#. description, to be sure
#. * that opening modes will be excluded from the translation (experience
#. shows that using a
#. * translation context is not enough to ensure it)
#: mousepad/mousepad-application.c:407
#, c-format
msgid "File opening mode: \"%s\", \"%s\" or \"%s\" (open tabs in a new window)"
msgstr "ໂໝດການເປີດໄຟລ໌: \"%s\", \"%s\" ຫຼື \"%s\" (ເປີດແທັບໃນໜ້າຕ່າງໃໝ່)"

#: mousepad/mousepad-application.c:410
msgid "MODE"
msgstr "ໂໝດ"

#: mousepad/mousepad-application.c:468
msgid "The Mousepad developers. All rights reserved."
msgstr "ນັກພັດທະນາ Mousepad. ສະຫງວນລິຂະສິດທັງໝົດ."

#: mousepad/mousepad-application.c:469
#, c-format
msgid "Please report bugs to <%s>."
msgstr "ກະລຸນາລາຍງານຂໍ້ຜິດພາດໄປທີ່ <%s>."

#: mousepad/mousepad-application.c:1577
#, c-format
msgid "%s | Authors: %s | Filename: %s"
msgstr "%s | ຜູ້ຂຽນ: %s | ຊື່ໄຟລ໌: %s"

#: mousepad/mousepad-dialogs.c:69 org.xfce.mousepad.appdata.xml.in:8
msgid "Mousepad is a simple text editor for the Xfce desktop environment"
msgstr "Mousepad ແມ່ນໂປຣແກຣມແກ້ໄຂຂໍ້ຄວາມແບບງ່າຍດາຍສຳລັບສະພາບແວດລ້ອມເດັສທັອບ Xfce"

#: mousepad/mousepad-dialogs.c:76
msgid "translator-credits"
msgstr "ລາຍຊື່ຜູ້ແປ"

#. display an error message to the user
#: mousepad/mousepad-dialogs.c:123
msgid "Failed to open the documentation browser"
msgstr "ບໍ່ສາມາດເປີດຕົວທ່ອງເວັບເອກະສານໄດ້"

#. build dialog
#: mousepad/mousepad-dialogs.c:139
msgid "Select Tab Size"
msgstr "ເລືອກຂະໜາດແທັບ"

#. build the dialog
#: mousepad/mousepad-dialogs.c:231
msgid "Go To"
msgstr "ໄປທີ່"

#. add button
#: mousepad/mousepad-dialogs.c:239
msgid "_Jump to"
msgstr "_ໂດດໄປທີ່"

#: mousepad/mousepad-dialogs.c:259
msgid "_Line number:"
msgstr "ເລກ_ແຖວ:"

#: mousepad/mousepad-dialogs.c:279
msgid "C_olumn number:"
msgstr "ເລກ_ຖັນ:"

#: mousepad/mousepad-dialogs.c:339
msgid "Remove all entries from the documents history?"
msgstr "ລຶບລາຍການທັງໝົດອອກຈາກປະຫວັດເອກະສານບໍ່?"

#. setup CSD titlebar
#: mousepad/mousepad-dialogs.c:343
msgid "Clear Documents History"
msgstr "ລຶບປະຫວັດເອກະສານ"

#: mousepad/mousepad-dialogs.c:349
msgid ""
"Clearing the documents history will permanently remove all currently listed "
"entries."
msgstr "ການລຶບປະຫວັດເອກະສານຈະເປັນການລຶບລາຍການທັງໝົດທີ່ມີຢູ່ໃນຕອນນີ້ຢ່າງຖາວອນ."

#: mousepad/mousepad-dialogs.c:356
msgid "Clea_r"
msgstr "_ລຶບ"

#: mousepad/mousepad-dialogs.c:382
msgid "Do you want to save the changes before closing?"
msgstr "ທ່ານຕ້ອງການບັນທຶກການປ່ຽນແປງກ່ອນປິດບໍ່?"

#: mousepad/mousepad-dialogs.c:384
msgid "The document is read-only, do you want to save it as another file?"
msgstr "ເອກະສານນີ້ແມ່ນອ່ານໄດ້ຢ່າງດຽວ, ທ່ານຕ້ອງການບັນທຶກເປັນໄຟລ໌ອື່ນບໍ່?"

#. setup CSD titlebar
#: mousepad/mousepad-dialogs.c:392 mousepad/mousepad-dialogs.c:532
msgid "Save Changes"
msgstr "ບັນທຶກການປ່ຽນແປງ"

#: mousepad/mousepad-dialogs.c:402
msgid "_Don't Save"
msgstr "_ບໍ່ບັນທຶກ"

#: mousepad/mousepad-dialogs.c:408
msgid ""
"If you don't save this read-only document as another file, all the changes "
"will be lost."
msgstr "ຖ້າທ່ານບໍ່ບັນທຶກເອກະສານທີ່ອ່ານໄດ້ຢ່າງດຽວນີ້ເປັນໄຟລ໌ອື່ນ, ການປ່ຽນແປງທັງໝົດຈະສູນຫາຍ."

#: mousepad/mousepad-dialogs.c:415
msgid "If you don't save the document, all the changes will be lost."
msgstr "ຖ້າທ່ານບໍ່ບັນທຶກເອກະສານ, ການປ່ຽນແປງທັງໝົດຈະສູນຫາຍ."

#: mousepad/mousepad-dialogs.c:456
msgid ""
"The document has been externally modified. Do you want to continue saving?"
msgstr "ເອກະສານຖືກແກ້ໄຂຈາກພາຍນອກ. ທ່ານຕ້ອງການບັນທຶກຕໍ່ໄປບໍ່?"

#: mousepad/mousepad-dialogs.c:457
msgid "If you save the document, all of the external changes will be lost."
msgstr "ຖ້າທ່ານບັນທຶກເອກະສານ, ການປ່ຽນແປງຈາກພາຍນອກທັງໝົດຈະສູນຫາຍ."

#: mousepad/mousepad-dialogs.c:464
msgid ""
"The document has been externally modified. Do you want to reload it from "
"disk?"
msgstr "ເອກະສານຖືກແກ້ໄຂຈາກພາຍນອກ. ທ່ານຕ້ອງການໂຫລດໃໝ່ຈາກດິສກ໌ບໍ່?"

#: mousepad/mousepad-dialogs.c:469
msgid "You have unsaved changes. If you revert the file, they will be lost."
msgstr "ທ່ານມີການປ່ຽນແປງທີ່ຍັງບໍ່ທັນໄດ້ບັນທຶກ. ຖ້າທ່ານຄືນຄ່າໄຟລ໌, ພວກມັນຈະສູນຫາຍ."

#. setup CSD titlebar
#: mousepad/mousepad-dialogs.c:487
msgid "Externally Modified"
msgstr "ຖືກແກ້ໄຂຈາກພາຍນອກ"

#: mousepad/mousepad-dialogs.c:528
msgid "Do you want to save your changes before reloading?"
msgstr "ທ່ານຕ້ອງການບັນທຶກການປ່ຽນແປງກ່ອນໂຫລດໃໝ່ບໍ່?"

#: mousepad/mousepad-dialogs.c:538
msgid "If you revert the file, all unsaved changes will be lost."
msgstr "ຖ້າທ່ານຄືນຄ່າໄຟລ໌, ການປ່ຽນແປງທັງໝົດທີ່ບໍ່ໄດ້ບັນທຶກຈະສູນຫາຍ."

#: mousepad/mousepad-dialogs.c:576
#, c-format
msgid ""
"The file seems to be encoded in %s, but you have chosen %s encoding. Do you "
"confirm this choice?"
msgstr "ໄຟລ໌ເບິ່ງຄືວ່າຖືກເຂົ້າລະຫັດໃນ %s, ແຕ່ທ່ານໄດ້ເລືອກລະຫັດ %s. ທ່ານຢືນຢັນການເລືອກນີ້ບໍ່?"

#: mousepad/mousepad-dialogs.c:586
msgid "If not, the guessed encoding will be used."
msgstr "ຖ້າບໍ່ດັ່ງນັ້ນ, ຈະໃຊ້ລະຫັດທີ່ຄາດເດົາໄວ້."

#: mousepad/mousepad-dialogs.c:641
msgid ""
"It seems that the previous session did not end normally. Do you want to "
"restore the available data?"
msgstr "ເບິ່ງຄືວ່າເຊດຊັນກ່ອນໜ້ານີ້ບໍ່ໄດ້ປິດລົງແບບປົກກະຕິ. ທ່ານຕ້ອງການກູ້ຄືນຂໍ້ມູນທີ່ມີຢູ່ບໍ່?"

#: mousepad/mousepad-dialogs.c:660
msgid "If not, all this data will be lost."
msgstr "ຖ້າບໍ່ດັ່ງນັ້ນ, ຂໍ້ມູນທັງໝົດນີ້ຈະສູນຫາຍ."

#: mousepad/mousepad-dialogs.c:863
msgid "Please select a file"
msgstr "ກະລຸນາເລືອກໄຟລ໌"

#: mousepad/mousepad-dialogs.c:906
msgid "Failed to prepare the temporary file for encoding tests"
msgstr "ບໍ່ສາມາດກຽມໄຟລ໌ຊົ່ວຄາວເພື່ອທົດສອບລະຫັດຕົວອັກສອນໄດ້"

#: mousepad/mousepad-dialogs.c:969 mousepad/mousepad-dialogs.c:1042
msgid "Open encoding dialog"
msgstr "ເປີດໜ້າຕ່າງລະຫັດຕົວອັກສອນ"

#: mousepad/mousepad-dialogs.c:971
msgid "Go back to shorten list"
msgstr "ກັບຄືນໄປຫາລາຍຊື່ແບບຫຍໍ້"

